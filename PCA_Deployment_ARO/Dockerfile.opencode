# Custom DevSpaces image with OpenCode AI coding agent pre-installed.
# Based on the Red Hat Universal Developer Image (UDI) for DevSpaces.
#
# Build:
#   podman build -f Dockerfile.opencode -t quay.io/<org>/devspaces-opencode:latest .
#
# Push:
#   podman push quay.io/<org>/devspaces-opencode:latest
FROM registry.redhat.io/devspaces/udi-rhel8:latest

USER root

# Install OpenCode and tmux (for persistent sessions across browser disconnects)
RUN curl -fsSL https://opencode.ai/install | bash && \
    dnf install -y tmux && \
    dnf clean all

# OpenCode global config — points to the cluster-internal llm-d gateway.
# The model name and endpoint will be overridable via ConfigMap or env vars.
RUN mkdir -p /home/user/.config/opencode /home/user/.local/share/opencode

COPY <<'OPENCODE_CONFIG' /home/user/.config/opencode/opencode.json
{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "vllm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Private AI Gateway (llm-d)",
      "options": {
        "baseURL": "https://llm-d-gateway-data-science-gateway-class.ai-serving.svc.cluster.local/v1"
      },
      "models": {
        "Qwen/Qwen3.6-35B-A3B-FP8": {
          "name": "Qwen3.6 35B (Private AI)"
        }
      }
    }
  },
  "model": "vllm/Qwen/Qwen3.6-35B-A3B-FP8"
}
OPENCODE_CONFIG

COPY <<'AUTH_JSON' /home/user/.local/share/opencode/auth.json
{
  "vllm": {
    "type": "api",
    "key": "EMPTY"
  }
}
AUTH_JSON

RUN chown -R 1001:0 /home/user/.config/opencode /home/user/.local/share/opencode && \
    chmod -R g=u /home/user/.config/opencode /home/user/.local/share/opencode

USER 1001
