# Custom DevSpaces image with OpenCode AI coding agent pre-installed.
# Based on the Red Hat Universal Developer Image (UDI) for DevSpaces.
#
# Build:
#   podman build -f Dockerfile.opencode -t quay.io/<org>/devspaces-opencode:latest .
#
# Push:
#   podman push quay.io/<org>/devspaces-opencode:latest
FROM registry.redhat.io/devspaces/udi-rhel8:latest

USER root

# Install OpenCode CLI (AI coding agent).
# Copy binary to /usr/local/bin (always in PATH) rather than symlink in
# ~/.local/bin which gets overwritten by the DevSpaces runtime overlay.
RUN curl -fsSL https://opencode.ai/install | bash && \
    cp /home/user/.opencode/bin/opencode /usr/local/bin/opencode && \
    chmod 755 /usr/local/bin/opencode

# OpenCode global config — points to the cluster-internal llm-d EPP gateway.
RUN mkdir -p /home/user/.config/opencode /home/user/.local/share/opencode && \
    echo '{"$schema":"https://opencode.ai/config.json","provider":{"vllm":{"npm":"@ai-sdk/openai-compatible","name":"Private AI Gateway (llm-d)","options":{"baseURL":"https://llm-d-gateway-data-science-gateway-class.ai-serving.svc.cluster.local/v1"},"models":{"Qwen/Qwen3.6-35B-A3B-FP8":{"name":"Qwen3.6 35B (Private AI)"}}}},"model":"vllm/Qwen/Qwen3.6-35B-A3B-FP8"}' > /home/user/.config/opencode/opencode.json && \
    echo '{"vllm":{"type":"api","key":"EMPTY"}}' > /home/user/.local/share/opencode/auth.json && \
    chown -R 1001:0 /home/user/.config/opencode /home/user/.local/share/opencode && \
    chmod -R g=u /home/user/.config/opencode /home/user/.local/share/opencode

ENV NODE_TLS_REJECT_UNAUTHORIZED=0

USER 1001
