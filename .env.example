# ──────────────────────────────────────────────
# Private AI Code Assistant — Credentials
# Copy to .env and fill in your values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────

# AWS Credentials
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_ACCOUNT_ID=
AWS_DEFAULT_REGION=us-east-2

# Red Hat OCM / ROSA Token (offline refresh token)
# Get yours at: https://console.redhat.com/openshift/token
RHCS_TOKEN=

# HuggingFace Token
HUGGINGFACE_TOKEN=

# Cluster Admin Password
CLUSTER_ADMIN_PASSWORD=

# Azure (for ARO deployments)
# ARM_SUBSCRIPTION_ID=
